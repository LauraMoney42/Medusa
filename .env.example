# Medusa Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server
HOST=0.0.0.0
PORT=3456

# Auth — set a strong random token (required for remote access)
AUTH_TOKEN=pick-a-random-secret-here

# Claude accounts (optional — defaults shown)
# ACCOUNT_1_NAME=Personal
# ACCOUNT_1_CONFIG_DIR=~/.claude
# ACCOUNT_2_NAME=Work
# ACCOUNT_2_CONFIG_DIR=~/.claude-account2

# Hub polling — enable for background bot check-ins (optional)
# HUB_POLLING=true
# HUB_POLL_INTERVAL_MS=120000

# Advanced (optional)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# GRACEFUL_TIMEOUT_MS=30000
# SUMMARIZATION_ENABLED=true
# SUMMARIZATION_THRESHOLD=30
# MODEL_ROUTING_ENABLED=true
# STALE_TASK_THRESHOLD_MS=600000

# ── OneNote MCP (med-010) ─────────────────────────────────────────────────────
# Required for OneNote read/search/create via Claude tool calls.
# Register an Azure app at https://portal.azure.com → Azure Active Directory → App registrations
# Grant Microsoft Graph permissions: Notes.Read, Notes.ReadWrite, Notes.ReadWrite.All
# See docs/ONENOTE_SETUP.md for step-by-step instructions.
# AZURE_TENANT_ID=your-tenant-id-here
# AZURE_CLIENT_ID=your-client-id-here
# AZURE_CLIENT_SECRET=your-client-secret-here
